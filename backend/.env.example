# ============================================================
# SIDEM-PAN — Backend Environment Variables
# Copia este archivo a .env y completa los valores
# ============================================================

NODE_ENV=development
PORT=4000

# Base de datos — Supabase
# Obten la connection string en:
# Supabase Dashboard > Settings > Database > Connection string > URI (Session mode)
# Formato: postgresql://postgres.[REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.wlzrvuwuhbtrjobcarar:TU_PASSWORD@aws-0-TU_REGION.pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro_minimo_32_chars
JWT_EXPIRES_IN=15m

# Almacenamiento de archivos PDF
UPLOADS_DIR=./uploads

# Supabase (para operaciones directas via cliente JS si se necesita)
SUPABASE_URL=https://wlzrvuwuhbtrjobcarar.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui
